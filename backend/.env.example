# ============================================================
#  Mẫu cấu hình secret — copy thành `.env` và điền giá trị thật.
#  `.env` đã được .gitignore (KHÔNG bao giờ commit).
#  Docker Compose tự nạp các biến này thành env var cho container.
# ============================================================

# --- Bắt buộc ---
JWT_KEY=<chuoi-ngau-nhien-toi-thieu-32-byte>   # openssl rand -base64 48
INGEST_TOKEN=<token-cho-extension>             # openssl rand -hex 16
POSTGRES_PASSWORD=<mat-khau-db>

# --- Tuỳ chọn ---
CORS_ORIGIN=http://localhost:5173
GEMINI_API_KEY=                                # AIza... (để trống thì bỏ qua dịch Trung→Việt)

# Admin seed (PROD: đặt giá trị thật, KHÔNG dùng mặc định demo)
SEED_ADMIN_EMAIL=maianh@gomdon.vn
SEED_ADMIN_PASSWORD=demo1234
SEED_ADMIN_NAME=Quản trị viên

# ============================================================
#  Dev local KHÔNG dùng Docker (chạy `dotnet run`):
#  secret nạp qua User Secrets thay vì .env —
#    dotnet user-secrets set "Jwt:Key" "<...>"      --project src/GomDon.Api
#    dotnet user-secrets set "Ingest:Token" "<...>" --project src/GomDon.Api
#    dotnet user-secrets set "Gemini:ApiKey" "<...>" --project src/GomDon.Api
# ============================================================
