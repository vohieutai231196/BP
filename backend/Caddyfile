# Production: chỉ phục vụ qua HTTPS trên domain. HTTP tự redirect sang HTTPS.
gomdons.com {
	encode gzip

	# Mọi API đều dưới /v1/* ; thêm /health, /swagger để debug.
	@api path /v1/* /health /swagger /swagger/*
	handle @api {
		reverse_proxy api:8080
	}

	# Còn lại phục vụ FE tĩnh (SPA → fallback index.html).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

# www → tên miền gốc.
www.gomdons.com {
	redir https://gomdons.com{uri} permanent
}
